#
# SwayWM idle config
#

# Lock screen after 300 seconds of inactivity, turn off displays after
# another 300 seconds and turn them back on when resumed. Also lock the
# screen before sleeping.
exec swayidle -w \
    timeout 300 'swaylock -f -c $lockscreencolor' \
    timeout 600 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
    before-sleep 'swaylock -f -c $lockscreencolor'

# Lock the screen
bindsym $mod+Shift+x exec 'swaylock -f -c $lockscreencolor'
