#
# SwayWM input config
#
# You can get the names of your inputs by running: swaymsg -t get_inputs
# Read `man 5 sway-input` for more information about this section.

input type:keyboard {
    xkb_numlock enable
}

input type:pointer {
    accel_profile flat
    pointer_accel 0
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
    pointer_accel 0.2
}
