syntax enable " Explorer and syntax highlighting
set showmode " Show the current editor mode
set showcmd " Show commands in the status bar
set wildmenu " Command autocompletion
set ruler " Status info
runtime ftplugin/man.vim " Man pages
set autoindent " Indent smartly
set expandtab " Expand tabs into spaces
set nowrap " Don't wrap text
set hlsearch " Highlight all search matches
set showmatch " Show matches for braces, parents, etc.
set ignorecase " Search case-insensitive
set smartcase " Search case-sensitive when using an uppercase
set number " Show line numbers
